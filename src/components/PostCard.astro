---
export interface Props {
  title: string;
  date: Date;
  tags: string[];
  description: string;
  readingTime: string;
  slug: string;
}

const { title, date, tags, description, readingTime, slug } = Astro.props;
const postSlug = slug.replace(/\.md$/, '');
---

<article class="post-card">
  <h2 class="post-title">
    <a href={`/blog/posts/${postSlug}`}>{title}</a>
  </h2>
  <div class="post-meta">
    <time datetime={date.toISOString()}>{date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    <span class="separator">·</span>
    <span>{readingTime}</span>
  </div>
  {description && <p class="post-desc">{description}</p>}
  {tags.length > 0 && (
    <div class="post-tags">
      {tags.map(tag => (
        <a href={`/blog/tags/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-title {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    line-height: 1.4;
    border: none;
  }

  .post-title a {
    color: var(--text);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .separator {
    color: var(--border);
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .tag:hover {
    opacity: 0.8;
    text-decoration: none;
  }
</style>
