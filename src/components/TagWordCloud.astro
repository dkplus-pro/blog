---
export interface TagDatum {
  word: string;
  weight: number;
}

export interface Props {
  tags: TagDatum[];
}

const { tags } = Astro.props;
---

<div class="tag-wordcloud-wrap">
  <div id="tag-wordcloud-chart" class="tag-wordcloud-chart" data-tags={JSON.stringify(tags)} />
  <p class="tag-wordcloud-hint">点击词云中的标签可查看文章 · 悬停显示数量</p>

  <ul class="tag-count-list" role="list">
    {tags.map(({ word, weight }) => (
      <li role="listitem">
        <a href={`/blog/tags/${word}`} class="tag-count-item">
          <span class="tag-count-name">{word}</span>
          <span class="tag-count-badge">{weight}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  interface TagDatum {
    word: string;
    weight: number;
  }

  type Rgb = [number, number, number];

  function parseCssColor(input: string): Rgb | null {
    const s = input.trim();
    if (!s) return null;
    if (s.startsWith('#')) {
      const hex = s.slice(1);
      const full =
        hex.length === 3
          ? hex
              .split('')
              .map((c) => c + c)
              .join('')
          : hex;
      if (full.length !== 6) return null;
      return [
        parseInt(full.slice(0, 2), 16),
        parseInt(full.slice(2, 4), 16),
        parseInt(full.slice(4, 6), 16),
      ];
    }
    const m = s.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
    if (m) return [Number(m[1]), Number(m[2]), Number(m[3])];
    return null;
  }

  function mixRgb(a: Rgb, b: Rgb, t: number): string {
    const r = Math.round(a[0] + (b[0] - a[0]) * t);
    const g = Math.round(a[1] + (b[1] - a[1]) * t);
    const bl = Math.round(a[2] + (b[2] - a[2]) * t);
    return `rgb(${r}, ${g}, ${bl})`;
  }

  function weightRatio(weight: number, min: number, max: number): number {
    if (max <= min) return 1;
    return (weight - min) / (max - min);
  }

  /** 文章数越少颜色越浅，越多越接近主题色 */
  function colorForWeight(
    weight: number,
    min: number,
    max: number,
    accent: Rgb,
    bg: Rgb,
    minMix = 0.32,
  ): string {
    const t = minMix + (1 - minMix) * weightRatio(weight, min, max);
    return mixRgb(bg, accent, t);
  }

  function getThemePalette(): { accent: Rgb; hover: Rgb; bg: Rgb } {
    const style = getComputedStyle(document.documentElement);
    const accent =
      parseCssColor(style.getPropertyValue('--tag-text')) ??
      parseCssColor(style.getPropertyValue('--accent')) ?? [9, 105, 218];
    const hover =
      parseCssColor(style.getPropertyValue('--accent-hover')) ?? accent;
    const bg =
      parseCssColor(style.getPropertyValue('--bg')) ??
      parseCssColor(style.getPropertyValue('--bg-primary')) ?? [255, 255, 255];
    return { accent, hover, bg };
  }

  async function initTagWordCloud(container: HTMLElement) {
    const { WordCloud } = await import('@antv/g2plot');

    const raw = container.dataset.tags;
    if (!raw) return;

    let data: TagDatum[];
    try {
      data = JSON.parse(raw);
    } catch {
      console.error('[TagWordCloud] 标签数据解析失败');
      return;
    }

    if (data.length === 0) return;

    const weights = data.map((d) => d.weight);
    const minWeight = Math.min(...weights);
    const maxWeight = Math.max(...weights);

    let plot: InstanceType<typeof WordCloud> | null = null;
    let rendering = false;
    let hoveredShape: { set: (k: string, v: unknown) => void } | null = null;
    let hoveredFill = '';

    const render = async () => {
      const width = container.clientWidth;
      if (width <= 0 || rendering) return;

      rendering = true;
      const { accent, hover, bg } = getThemePalette();
      const hoverFill = mixRgb(accent, hover, 0.55);

      const resolveWeight = (datum: {
        value?: number;
        datum?: TagDatum;
      }): number => datum.datum?.weight ?? datum.value ?? minWeight;

      try {
        if (plot) {
          plot.destroy();
          plot = null;
        }
        hoveredShape = null;

        plot = new WordCloud(container, {
          data,
          wordField: 'word',
          weightField: 'weight',
          width,
          height: 360,
          autoFit: false,
          padding: 0,
          appendPadding: 0,
          spiral: 'archimedean',
          random: () => 0.5,
          color: (datum: { value?: number; datum?: TagDatum }) =>
            colorForWeight(resolveWeight(datum), minWeight, maxWeight, accent, bg),
          wordStyle: {
            fontFamily:
              "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', sans-serif",
            fontSize: [14, 48],
            rotation: [0, 0],
            rotationSteps: 1,
            padding: 4,
          },
          tooltip: {
            showTitle: false,
            fields: ['text', 'value'],
            formatter: (datum: { text?: string; value?: number }) => ({
              name: datum.text ?? '',
              value: `${datum.value ?? 0} 篇文章`,
            }),
          },
          legend: false,
          interactions: [],
        });

        plot.on('element:click', (evt: { data?: { data?: { datum?: TagDatum } } }) => {
          const word = evt?.data?.data?.datum?.word;
          if (word) {
            window.location.href = `/blog/tags/${word}`;
          }
        });

        plot.on('element:mouseenter', (evt: { target?: { attr: (k: string) => unknown; set: (k: string, v: unknown) => void } }) => {
          const shape = evt.target;
          if (!shape?.attr('text')) return;

          if (hoveredShape && hoveredShape !== shape) {
            hoveredShape.set('fill', hoveredFill);
            hoveredShape.set('fontWeight', 'normal');
          }

          hoveredShape = shape;
          hoveredFill = String(shape.attr('fill') ?? '');
          shape.set('fill', hoverFill);
          shape.set('fontWeight', 600);
          container.style.cursor = 'pointer';
        });

        plot.on('element:mouseleave', (evt: { target?: { set: (k: string, v: unknown) => void } }) => {
          const shape = evt.target;
          if (shape && shape === hoveredShape) {
            shape.set('fill', hoveredFill);
            shape.set('fontWeight', 'normal');
            hoveredShape = null;
            container.style.cursor = '';
          }
        });

        await plot.render();
      } catch (err) {
        console.error('[TagWordCloud] 词云渲染失败', err);
      } finally {
        rendering = false;
      }
    };

    await render();

    let resizeTimer: ReturnType<typeof setTimeout>;
    const ro = new ResizeObserver(() => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => void render(), 150);
    });
    ro.observe(container);

    const themeObserver = new MutationObserver(() => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => void render(), 150);
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  const chartEl = document.getElementById('tag-wordcloud-chart');
  if (chartEl) void initTagWordCloud(chartEl);
</script>

<style>
  .tag-wordcloud-wrap {
    width: 100%;
  }

  .tag-wordcloud-chart {
    width: 100%;
    height: 360px;
    margin: 0 auto;
  }

  .tag-wordcloud-chart :global(canvas) {
    display: block;
  }

  .tag-wordcloud-hint {
    margin: 0.5rem 0 1.25rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-align: center;
  }

  .tag-count-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }

  .tag-count-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    font-size: 0.85rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .tag-count-item:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .tag-count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.35rem;
    font-size: 0.7rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    background: var(--bg);
    border-radius: 999px;
    color: var(--text-secondary);
  }
</style>
