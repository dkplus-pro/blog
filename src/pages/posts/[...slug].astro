---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = Astro.params.slug;
const { Content, headings } = await post.render();

function getReadingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.ceil(words / 400));
  return `${minutes} 分钟阅读`;
}

const readingTime = getReadingTime(post.body);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIndex = allPosts.findIndex(p => p.id.replace(/\.md$/, '') === slug);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-full">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="separator">·</span>
        <span>{readingTime}</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <a href={`/blog/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    {headings.length > 0 && (
      <nav class="toc">
        <h3 class="toc-title">目录</h3>
        <ul class="toc-list">
          {headings.filter(h => h.depth <= 3).map(h => (
            <li class={`toc-item toc-depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="post-content">
      <Content />
    </div>

    <nav class="post-nav">
      {prevPost && (
        <a href={`/blog/posts/${prevPost.id.replace(/\.md$/, '')}`} class="post-nav-link prev">
          <span class="post-nav-label">← 上一篇</span>
          <span class="post-nav-title">{prevPost.data.title}</span>
        </a>
      )}
      {nextPost && (
        <a href={`/blog/posts/${nextPost.id.replace(/\.md$/, '')}`} class="post-nav-link next">
          <span class="post-nav-label">下一篇 →</span>
          <span class="post-nav-title">{nextPost.data.title}</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<script>
  document.querySelectorAll('pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code.textContent || '');
        btn.textContent = '已复制';
        setTimeout(() => { btn.textContent = '复制'; }, 2000);
      } catch {
        btn.textContent = '失败';
      }
    });
    pre.appendChild(btn);
  });
</script>

<style>
  .post-full {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-title {
    font-size: 2rem;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .post-meta {
    font-size: 0.9rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .separator { color: var(--border); }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .tag:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  .toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .toc-title {
    font-size: 0.9rem;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item { margin-bottom: 0.25rem; }

  .toc-item a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .toc-item a:hover {
    color: var(--accent);
  }

  .toc-depth-2 { padding-left: 0; }
  .toc-depth-3 { padding-left: 1rem; }

  .post-content {
    line-height: 1.8;
    font-size: 1rem;
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    scroll-margin-top: 72px;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    flex: 1;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .post-nav-link:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .post-nav-link.next {
    text-align: right;
  }

  .post-nav-link:empty { display: none; }

  .post-nav-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .post-nav-title {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 500;
  }
</style>
